{
	"name": "allan-aoudji",
	"version": "0.1.0",
	"private": true,
	"engines": {
		"node": "24.x"
	},
	"scripts": {
		"clean": "rm -rf .next",
		"clean:build": "rm -rf .next && next build --webpack",
		"dev": "next dev",
		"build": "next build --webpack",
		"start": "next start",
		"type-check": "tsc -b",
		"format": "prettier --write .",
		"prepare": "husky || true",
		"predev": "npm run typegen",
		"prebuild": "npm run typegen",
		"typegen": "sanity schema extract --enforce-required-fields --path=./sanityBackend/extract.json && sanity typegen generate"
	},
	"lint-staged": {
		"*.{ts,tsx}": [
			"eslint --fix",
			"prettier --write"
		],
		"*.{json,md,css}": [
			"prettier --write"
		]
	},
	"dependencies": {
		"@sanity/asset-utils": "^2.2.1",
		"@sanity/cli": "^6.2.0",
		"@sanity/icons": "^3.7.4",
		"@sanity/image-url": "^2.0.3",
		"@sanity/orderable-document-list": "^1.5.1",
		"@sanity/vision": "^5.18.0",
		"@sentry/nextjs": "^10.47.0",
		"@serwist/next": "^9.5.7",
		"@tabler/icons-react": "^3.40.0",
		"@upstash/redis": "^1.37.0",
		"@vercel/analytics": "^2.0.1",
		"@vercel/speed-insights": "^2.0.0",
		"clsx": "^2.1.1",
		"easymde": "^2.20.0",
		"focus-trap-react": "^12.0.0",
		"html-react-parser": "^5.2.17",
		"motion": "^12.27.5",
		"next": "16.2.3",
		"next-sanity": "^12.2.2",
		"rate-limiter-flexible": "^10.0.1",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"react-icons": "^5.5.0",
		"require-in-the-middle": "^8.0.1",
		"resend": "^6.9.4",
		"sanity": "^5.18.0",
		"sanity-plugin-markdown": "^8.0.5",
		"sanity-plugin-media": "^4.1.1",
		"server-only": "^0.0.1",
		"serwist": "^9.5.7",
		"styled-components": "^6.1.19",
		"tailwind-merge": "^3.4.0",
		"zod": "^3.25.74"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"@eslint/eslintrc": "^3",
		"@tailwindcss/postcss": "^4",
		"@tailwindcss/typography": "^0.5.16",
		"@trivago/prettier-plugin-sort-imports": "^5.2.2",
		"@types/node": "^22",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"eslint": "^9",
		"eslint-config-next": "16.2.3",
		"eslint-config-prettier": "^10.1.5",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"prettier": "^3.6.2",
		"prettier-plugin-tailwindcss": "^0.6.13",
		"tailwindcss": "^4",
		"typescript": "^5"
	}
}
